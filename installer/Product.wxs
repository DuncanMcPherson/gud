<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
    <Package Name="gud"
             Manufacturer="Duncan McPherson"
             Version="$(var.Version)"
             UpgradeCode="743764DF-CBDD-4275-BF11-7EE995AC4217">
        <MajorUpgrade DowngradeErrorMessage="A newer version of gud is already installed." />
        <MediaTemplate EmbedCab="yes"/>
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="gud">
                <Component Id="MainExecutable" Guid="*">
                    <File Id="GudExe" Source="$(var.PublishDir)/gud.exe" KeyPath="yes" />
                    <Environment Id="PathEntry" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes"/>
                </Component>
            </Directory>
        </StandardDirectory>
        
        <Feature Id="MainFeature" Title="gud" Level="1">
            <ComponentRef Id="MainExecutable" />
        </Feature>
        
        <ui:WixUI Id="WixUI_InstallDir"  InstallDirectory="INSTALLFOLDER"/>
    </Package>
</Wix>